nyc_tlc:
  outputs:
    dev:
      type: duckdb
      path: ./data/warehouse.duckdb
      threads: 1
      settings:
        # Allows DuckDB to reorder rows during writes — significantly reduces
        # memory pressure when materializing large tables from parquet sources.
        preserve_insertion_order: false

    prod:
      type: duckdb
      path: prod.duckdb
      threads: 4
      settings:
        preserve_insertion_order: false

  target: dev
